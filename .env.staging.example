# Jake's Home Appliances SOMS — staging environment template.
#
# Lives at /opt/jakes-home-appliances-soms/.env on the server (chmod 600, deploy:deploy).
# Never committed. Generate the four secrets with:
#   openssl rand -hex 64    # one each for JWT, REFRESH, CRON, POSTGRES
#
# docker-compose.yml overrides DATABASE_URL / DIRECT_URL at runtime to point
# at the in-cluster `postgres` service — only the four secrets and the app
# URL need to be set here.

# ── Postgres (consumed by docker-compose.yml) ────────────────────────────
POSTGRES_USER=soms
POSTGRES_DB=soms
POSTGRES_PASSWORD=

# ── Auth (consumed by src/lib/auth/jwt.ts via process.env) ───────────────
JWT_SECRET=
REFRESH_SECRET=

# ── Cron (consumed by src/lib/cron/guard.ts) ─────────────────────────────
# All seven systemd-driven cron jobs send Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=

# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://103.27.60.70

# ── Notification providers — stay on mock for staging ────────────────────
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock

# ── Container image — overridden by deploy workflow to a specific SHA ────
# Defaults to the floating `:staging` tag in docker-compose.yml; the GitHub
# Actions workflow rewrites this line on each deploy.
APP_IMAGE=ghcr.io/jojaketaemoon/jakeshomeapp-soms:staging
