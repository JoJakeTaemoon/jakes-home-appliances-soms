{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "deploy": true,
      "master": false,
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/overdue-escalation",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/filter-due",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/rental-renewal",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/rental-completion",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/visit-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/cash-handover-alert",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/recurring-payments",
      "schedule": "0 0 1 * *"
    }
  ]
}
