# Copy to `.env` and fill in. `.env` is gitignored.
# Generate secrets with: openssl rand -hex 64

# Postgres
DATABASE_URL="postgresql://USER@localhost:5432/jakes_home_appliances_soms"
DIRECT_URL="postgresql://USER@localhost:5432/jakes_home_appliances_soms"

# Auth secrets (64-byte hex each)
JWT_SECRET=""
REFRESH_SECRET=""

# Notification providers (mock-first for local; swap to esms/resend on prod cutover)
SMS_PROVIDER="mock"
EMAIL_PROVIDER="mock"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
