{
    "name": "jakes-home-appliances-soms",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && tsx scripts/check-db-connection.ts && next build",
        "start": "next start",
        "lint": "eslint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:ui:dev": "dotenv -e .env.dev -o -- npx playwright test --ui --project=desktop-chrome --reporter=list",
        "dev:coverage": "NODE_V8_COVERAGE=$PWD/coverage/server next dev",
        "test:e2e:coverage": "COVERAGE=1 playwright test --reporter=html",
        "coverage:report": "node scripts/coverage-report.mjs",
        "coverage:clean": "rm -rf coverage/server coverage/browser coverage/report playwright-report",
        "migration": "prisma migrate deploy",
        "migration:dev": "dotenv -e .env.dev -o -- prisma migrate dev",
        "db:seed": "npx prisma db seed",
        "db:seed:dev": "dotenv -e .env.dev -- npx prisma db seed",
        "db:reset": "npx prisma migrate deploy && npx prisma generate && npx tsx prisma/reset.ts && npx prisma db seed",
        "db:reset:dev": "dotenv -e .env.dev -o -- npx prisma migrate deploy && npx prisma generate && dotenv -e .env.dev -o -- npx tsx prisma/reset.ts && dotenv -e .env.dev -o -- npx prisma db seed",
        "vercel:deploy": "bash scripts/vercel-deploy.sh",
        "manuals:pdf": "npx tsx scripts/manuals/build-pdf.ts",
        "manuals:screenshots": "npx tsx scripts/manuals/capture-screenshots.ts",
        "manuals:all": "npm run manuals:screenshots && npm run manuals:pdf"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/adapter-pg": "^7.6.0",
        "@prisma/client": "^7.6.0",
        "@react-pdf/renderer": "^4.5.1",
        "@supabase/ssr": "^0.10.0",
        "@supabase/supabase-js": "^2.101.1",
        "@tanstack/react-query": "^5.96.2",
        "@vercel/speed-insights": "^2.0.0",
        "bcryptjs": "^3.0.3",
        "browser-image-compression": "^2.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dexie": "^4.4.2",
        "jose": "^6.2.2",
        "lucide-react": "^1.7.0",
        "next": "^16.2.6",
        "next-intl": "^4.9.0",
        "pdf-lib": "^1.17.1",
        "pg": "^8.20.0",
        "prisma": "^7.6.0",
        "react": "19.2.4",
        "react-day-picker": "^9.14.0",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.72.1",
        "recharts": "^3.8.1",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "prisma": {
        "seed": "npx tsx prisma/seed.ts"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^20",
        "@types/pg": "^8.20.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.2",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.2",
        "fake-indexeddb": "^6.2.5",
        "happy-dom": "^20.8.9",
        "jsdom": "^29.0.1",
        "markdown-it": "^14.2.0",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5",
        "vitest": "^4.1.2"
    }
}
